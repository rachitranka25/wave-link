# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
# For production, point this at Postgres instead, e.g.:
#   DATABASE_URL=postgresql://user:password@host:5432/wave_link
DATABASE_URL=sqlite:///./wave_link.db

# Path to a trained severity classifier (see app/ml/train.py). If the file
# doesn't exist, the app falls back to the rule-based heuristic in
# app/services/hf_nlp.py automatically — this is optional.
SEVERITY_MODEL_PATH=./data/severity_model.joblib

# Max write requests (POST/PATCH/PUT/DELETE) allowed per client IP per
# RATE_LIMIT_WINDOW_SECONDS. See app/middleware/rate_limit.py.
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
